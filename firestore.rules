rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Legal Cases — authenticated users can read and write.
    match /legalCases/{caseId} {
      allow read, write: if request.auth != null;
    }

    // Collection History — authenticated users can read and write.
    match /collectionHistory/{historyId} {
      allow read, write: if request.auth != null;
    }

    // Maintenance — any authenticated user can read, create, and update.
    // Only admins can delete.
    match /maintenance/{visitId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Technician work logs — same delete restriction as maintenance.
    match /technicianWork/{jobId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Pest Control — authenticated users can read and write.
    match /pestControl/{entryId} {
      allow read, write: if request.auth != null;
    }

    // Roles — any authenticated user can read, only admins can write.
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Utility Tracking — authenticated users can read and write.
    match /utilityTracking/{docId} {
      allow read, write: if request.auth != null;
    }

    // Meeting Templates — authenticated users can read and write.
    match /meetingTemplates/{templateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Meetings — authenticated users can read and write.
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // NOTE: Rules for other collections (properties, monthlyData, users,
    // invites, tasks) currently live only in the Firebase console and are
    // not yet mirrored here. Merge them in before deploying this file via
    // the CLI, otherwise existing access will be lost.
  }
}
