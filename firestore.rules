rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Legal Cases — authenticated users can read and write.
    match /legalCases/{caseId} {
      allow read, write: if request.auth != null;
    }

    // Collection History — authenticated users can read and write.
    match /collectionHistory/{historyId} {
      allow read, write: if request.auth != null;
    }

    // Maintenance — any authenticated user can read, create, and update.
    // Only admins can delete.
    match /maintenance/{visitId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Technician work logs — same delete restriction as maintenance.
    match /technicianWork/{jobId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Pest Control — authenticated users can read and write.
    match /pestControl/{entryId} {
      allow read, write: if request.auth != null;
    }

    // Roles — any authenticated user can read, only admins can write.
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Utility Tracking — authenticated users can read and write.
    match /utilityTracking/{docId} {
      allow read, write: if request.auth != null;
    }

    // Meeting Templates — authenticated users can read and write.
    match /meetingTemplates/{templateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Meetings — authenticated users can read and write.
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Call Log — authenticated users can read and write.
    match /callLog/{callId} {
      allow read, write: if request.auth != null;
    }

    // Invites — anyone can read (to validate tokens during signup) and
    // authenticated users can write. In production, consider restricting
    // writes to admins.
    match /invites/{inviteId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users — any authenticated user can read; users can create their own
    // doc on signup; updates require either being the doc owner or an
    // admin; deletes require admin. Prevents non-admins from changing
    // any other user's role or permissions.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Property History — any authenticated user can create logs,
    // only admins can read them.
    match /propertyHistory/{logId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null;
    }

    // Properties — any authenticated user can read and write.
    match /properties/{propId} {
      allow read, write: if request.auth != null;
    }

    // Monthly Data — any authenticated user can read and write.
    match /monthlyData/{docId} {
      allow read, write: if request.auth != null;
    }

    // Tasks — any authenticated user can read and write.
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}
